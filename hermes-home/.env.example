# ===== Matrix / Element =====
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USER_ID=@element-help:matrix.example.org
MATRIX_PASSWORD=CHANGE_ME
# Либо вместо MATRIX_USER_ID/MATRIX_PASSWORD используйте access token:
# MATRIX_ACCESS_TOKEN=CHANGE_ME

# Кто может писать боту напрямую / управлять им
MATRIX_ALLOWED_USERS=@admin1:matrix.example.org,@admin2:matrix.example.org

# Если нужен E2EE:
MATRIX_ENCRYPTION=true
# MATRIX_RECOVERY_KEY=CHANGE_ME
# MATRIX_HOME_ROOM=!abc123:matrix.example.org

# ===== LLM Provider =====
OPENAI_API_KEY=CHANGE_ME
# Или используйте другой провайдер, который реально подключён у вас:
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GLM_API_KEY=

# ===== Optional voice / other =====
# GROQ_API_KEY=
# VOICE_TOOLS_OPENAI_KEY=
