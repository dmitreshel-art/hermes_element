# ============================================
# Matrix / Element connection
# ============================================
# Ваш web/homeserver для Element
MATRIX_HOMESERVER=https://matrix.22brn.ru

# Учётная запись бота
MATRIX_USER_ID=CHANGE_ME
MATRIX_PASSWORD=CHANGE_ME
# Либо вместо MATRIX_USER_ID/MATRIX_PASSWORD используйте access token:
# MATRIX_ACCESS_TOKEN=CHANGE_ME

# Кто может писать боту напрямую
# Для старта можно оставить * и ограничить доступ на уровне Matrix-комнат/аккаунта
MATRIX_ALLOWED_USERS=*

# Если используете E2EE у бота
# MATRIX_ENCRYPTION=true
# MATRIX_RECOVERY_KEY=CHANGE_ME

# ============================================
# LLM Provider
# ============================================
# В базовой конфигурации используется OpenAI-совместимый провайдер
OPENAI_API_KEY=CHANGE_ME
# При необходимости замените провайдера в hermes-home/config.yaml и укажите
# соответствующий ключ:
# OPENROUTER_API_KEY=CHANGE_ME
# ANTHROPIC_API_KEY=CHANGE_ME
# GLM_API_KEY=CHANGE_ME
