# ============================================
# Matrix / Element connection
# ============================================
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USER_ID=@helpdesk:example.org
MATRIX_PASSWORD=CHANGE_ME
# Либо вместо MATRIX_USER_ID/MATRIX_PASSWORD используйте access token:
# MATRIX_ACCESS_TOKEN=CHANGE_ME

# Кто может писать боту напрямую
MATRIX_ALLOWED_USERS=*

# Если нужен E2EE:
# MATRIX_ENCRYPTION=true
# MATRIX_RECOVERY_KEY=CHANGE_ME

# ============================================
# LLM Provider
# ============================================
OPENAI_API_KEY=CHANGE_ME
# Или используйте другой провайдер:
# OPENROUTER_API_KEY=CHANGE_ME
# ANTHROPIC_API_KEY=CHANGE_ME
# GLM_API_KEY=CHANGE_ME
