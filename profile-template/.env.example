# ===== Matrix / Element =====
MATRIX_HOMESERVER=https://matrix.22brn.ru
MATRIX_USER_ID=@element-helpdesk:matrix.22brn.ru
MATRIX_PASSWORD=CHANGE_ME
# Alternatively use access token instead of MATRIX_USER_ID/MATRIX_PASSWORD:
# MATRIX_ACCESS_TOKEN=CHANGE_ME

# Who may interact with / administer the bot, comma-separated MXIDs.
MATRIX_ALLOWED_USERS=CHANGE_ME

# Enable only if the Matrix deployment and bot account require E2EE.
MATRIX_ENCRYPTION=false
# MATRIX_RECOVERY_KEY=CHANGE_ME
# MATRIX_HOME_ROOM=CHANGE_ME

# ===== LLM Provider =====
# For openai-codex OAuth, credentials may live in Hermes auth.json instead of this file.
OPENAI_API_KEY=CHANGE_ME
# OPENROUTER_API_KEY=CHANGE_ME
# ANTHROPIC_API_KEY=CHANGE_ME
# OLLAMA_API_KEY=CHANGE_ME
